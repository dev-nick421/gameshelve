# ---- GameLedger configuration -------------------------------------------------
# Copy to .env and adjust. NEVER commit a real .env

# Admin password protecting all admin routes
# REQUIRED — API refuses to start in production with this unset or left at a default.
ADMIN_PASSWORD=change-me-please

# Absolute path to the folder holding your games (mounted read-write).
LIBRARY_PATH=./games

# Host port the web UI is exposed on (default 8080 -> use different one if taken)
# WEB_PORT=8080

# ---- Prebuilt images (docker-compose.yml) -------------------------------------
# Override the owner if you forked/renamed the repo, and pin a release tag
# instead of the default `latest`
# IMAGE_OWNER=dev-nick421
# IMAGE_TAG=v1.0.0

# ---- Tuning -------------------------------------------------------------------
# Auto-match confidence threshold (0..1). Below this, games are left Unmatched
MATCH_THRESHOLD=0.6

# Refresh the IGDB OAuth token when fewer than this many ms remain (default 24h).
# TOKEN_REFRESH_WINDOW_MS=86400000

# SQLite database file inside the container (created on first run)
# The default is fine for Docker —> only change to relocate the DB.
# DATABASE_PATH=/app/data/gameledger.sqlite

# IGDB credentials (can also be set in admin UI)
# Obtain from https://dev.twitch.tv/console/apps
# IGDB_CLIENT_ID=
# IGDB_CLIENT_SECRET=
